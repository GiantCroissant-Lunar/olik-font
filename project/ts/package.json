{
  "name": "@olik/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build":     "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test":      "pnpm -r --parallel test",
    "lint":      "pnpm -r --parallel lint"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.7.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
