{
  "name": "@olik/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "test": "pnpm -r --parallel test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "lint:ci": "biome ci ."
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.7.5",
    "@biomejs/biome": "2.0.6"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
