{
  "name": "@olik/glyph-viz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@olik/glyph-schema": "workspace:*",
    "d3-hierarchy": "3.1.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.0.1",
    "@types/d3-hierarchy": "3.1.7",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.2"
  }
}
