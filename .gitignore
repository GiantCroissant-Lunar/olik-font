.vscode/

# Root-only — we don't want this to match .agent/skills/04-tooling/ref-projects/
/ref-projects/

.env

# macOS noise
.DS_Store

# Per-developer agent overlay — each dev maintains their own, treat like .env
AGENTS.md

# pass-1 additions
.worktrees/
# Ignore *contents* of project/py/data/ (not the dir itself) so we can
# carve out specific files with `!`.
project/py/data/*
!project/py/data/.gitkeep
# Committed dataset snapshot (Apache-2.0 from amake/cjk-decomp) and its
# license note — regenerate via `task data:regen-cjk-decomp`.
!project/py/data/cjk-decomp.json
!project/py/data/LICENSE-cjk-decomp
# MoE 4808 常用字 char list (public dataset from Watermelonnn/ChineseUsefulToolKit).
!project/py/data/moe_4808.txt
!project/py/data/LICENSE-moe-4808
# animCJK zh-Hant dataset snapshot used by Plan 13 Task B.
!project/py/data/animcjk/
!project/py/data/animcjk/**
!project/py/data/carved_components.json
project/py/.pytest_cache/
project/py/**/__pycache__/
project/py/src/*.egg-info/
project/py/htmlcov/
project/py/.coverage
project/ts/node_modules/
project/ts/**/node_modules/
project/ts/**/dist/
project/ts/**/.turbo/
project/ts/**/.next/
project/py/.venv/

# Archon runtime state (workflows under .archon/workflows/ ARE committed)
.archon/state/
.archon/.log/

# Local preview output from scripts/preview-glyph.py
preview/

# Live preview record dropbox — Archon workflows COPY freshly-generated
# glyph-record-*.json + prototype-library.json + rule-trace-*.json here so
# apps/quickview can serve them via Vite publicDir without depending on a
# specific worktree path. Persistent across workflow runs (overwritten).
.preview-records/

# TypeScript incremental build cache
project/ts/**/tsconfig.tsbuildinfo

# SurrealDB persistent data (surrealkv backend — hanfont/olik)
infra/surrealdb/data/
# Local DB → JSON snapshots from `task db:export`
infra/surrealdb/snapshots/
